BOARDSIGHT_ANALYSIS_PROFILE=production
BOARDSIGHT_LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# HUGGING_FACE_HUB_TOKEN=
# HF_TOKEN=
BOARDSIGHT_ENABLE_DIARIZATION=false
BOARDSIGHT_FASTER_WHISPER_MODEL=tiny.en
BOARDSIGHT_LIGHTWEIGHT_VISUAL_WINDOW_SECONDS=18
BOARDSIGHT_LIGHTWEIGHT_VISUAL_GAP_SECONDS=30
BOARDSIGHT_LIGHTWEIGHT_MAX_EVIDENCE_SEGMENTS=8

# Optional assignment delivery defaults. Workspace owners can alternatively save
# encrypted GitLab, Notion, and Trello connections from BoardSight Settings.
# BOARDSIGHT_GITLAB_BASE_URL=https://gitlab.com
# BOARDSIGHT_GITLAB_PROJECT_ID=group/project
# BOARDSIGHT_GITLAB_PRIVATE_TOKEN=
# BOARDSIGHT_NOTION_DATABASE_ID=
# BOARDSIGHT_NOTION_API_TOKEN=
# BOARDSIGHT_TRELLO_LIST_ID=
# BOARDSIGHT_TRELLO_API_KEY=
# BOARDSIGHT_TRELLO_API_TOKEN=
# BOARDSIGHT_MICROSOFT_TODO_LIST_ID=
# BOARDSIGHT_MICROSOFT_GRAPH_ACCESS_TOKEN=

# Razorpay Standard Checkout (server-side only; never expose the secret in browser code)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
